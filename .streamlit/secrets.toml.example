# Copy this file to secrets.toml and add your credentials.
# Never commit secrets.toml to git!
#
# Supabase (for deployed app persistence):
# DATABASE_URL = "postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres"
#
# Supabase Auth (for login/signup - optional):
# SUPABASE_URL = "https://[PROJECT_REF].supabase.co"
# SUPABASE_ANON_KEY = "your_anon_key"
# Get from: Supabase Dashboard → Project Settings → API
#
# Cookie encryption (for auth persistence across refresh - optional):
# COOKIES_PASSWORD = "a-random-secret-string"
#
# Groq (for AI insights when deployed):
# GROQ_API_KEY = "gsk_your_api_key"
# Get free key at: https://console.groq.com
